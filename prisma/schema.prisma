datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  HOMEOWNER
  DESIGNER
  ADMIN
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

enum TargetType {
  ROOM
  OBJECT
}

enum ScanStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum JobType {
  OBJECT_RECONSTRUCTION
  ROOM_MAPPING
  RECOMMENDATION
}

// ==========================================
// Authentication & User Management Models
// ==========================================

model User {
  id             String          @id @default(uuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?         // Used for fallback password login (credentials)
  role           Role            @default(HOMEOWNER)
  unitPreference UnitPreference  @default(METRIC)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // NextAuth Adapter Relations
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]

  // Locatra Application Relations
  projects       Project[]
  objects        Object[]
  scans          Scan[]
  preferences    Preference[]

  @@map("users")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

// ==========================================
// Locatra Application Core Models
// ==========================================

model Project {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  rooms     Room[]

  @@map("projects")
}

model Room {
  id              String           @id @default(uuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  lengthCm        Decimal          @db.Decimal(10, 2)
  widthCm         Decimal          @db.Decimal(10, 2)
  heightCm        Decimal          @db.Decimal(10, 2)
  meshUrl         String           // Pointer to GLB room digital twin
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  spaces          RoomSpace[]
  recommendations Recommendation[]
  placements      Placement[]

  @@map("rooms")
}

model RoomSpace {
  id             String           @id @default(uuid())
  roomId         String
  room           Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  label          String           // e.g., "Corner A"
  widthCm        Decimal          @db.Decimal(10, 2)
  depthCm        Decimal          @db.Decimal(10, 2)
  positionJson   Json             // 3D coordinates relative to room anchor (x, y, z)
  recommendations Recommendation[]

  @@map("room_spaces")
}

model Object {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  category        String           // e.g., "furniture.chair"
  heightCm        Decimal          @db.Decimal(10, 2)
  widthCm         Decimal          @db.Decimal(10, 2)
  depthCm         Decimal          @db.Decimal(10, 2)
  weightKg        Decimal?         @db.Decimal(6, 2)
  material        String?
  modelUrl        String           // Pointer to GLB object model
  createdAt       DateTime         @default(now())
  recommendations Recommendation[]
  placements      Placement[]

  @@map("objects")
}

model Scan {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType   TargetType
  targetId     String?     // Links to Room.id or Object.id once processed
  rawMediaUrl  String      // Uploaded video/images path in S3
  status       ScanStatus  @default(QUEUED)
  createdAt    DateTime    @default(now())
  jobs         AIJob[]

  @@map("scans")
}

model AIJob {
  id           String      @id @default(uuid())
  scanId       String
  scan         Scan        @relation(fields: [scanId], references: [id], onDelete: Cascade)
  jobType      JobType
  status       ScanStatus  @default(QUEUED)
  progressPct  Int         @default(0)
  errorMessage String?     @db.Text
  startedAt    DateTime    @default(now())
  completedAt  DateTime?

  @@map("ai_jobs")
}

model Recommendation {
  id                 String      @id @default(uuid())
  objectId           String
  object             Object      @relation(fields: [objectId], references: [id], onDelete: Cascade)
  roomId             String
  room               Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  recommendedSpaceId String
  recommendedSpace   RoomSpace   @relation(fields: [recommendedSpaceId], references: [id], onDelete: Cascade)
  confidenceScore    Decimal     @db.Decimal(3, 2) // Range: 0.00 to 1.00
  reasonsJson        Json        // String array containing explaining factors
  alternativesJson   Json        // Ranked alternatives metadata
  createdAt          DateTime    @default(now())
  placements         Placement[]

  @@map("recommendations")
}

model Placement {
  id               String          @id @default(uuid())
  recommendationId String?
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  objectId         String
  object           Object          @relation(fields: [objectId], references: [id], onDelete: Cascade)
  roomId           String
  room             Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  positionJson     Json            // Final pose: x, y, z, rotation, scale
  confirmedAt      DateTime        @default(now())

  @@map("placements")
}

model Preference {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String   // e.g., "prefers_wall_storage"
  valueJson   Json
  learnedFrom String   // "explicit" or "inferred"
  updatedAt   DateTime @default(now())

  @@map("preferences")
}
